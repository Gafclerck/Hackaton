# --- Requis ---
# URL de connexion a la base PostgreSQL (production)
DATABASE_URL=postgresql://user:password@localhost:5432/nom_de_la_base

# URL de connexion pour les migrations Alembic (dev)
DATABASE_URL_DEV=postgresql://user:password@localhost:5432/nom_de_la_base_dev

# Cle secrete pour signer les tokens JWT (generer une cle aleatoire)
SECRET_KEY=remplacer-par-une-cle-secrete-aleatoire

# --- Optionnel ---
# Origines CORS autorisees (defaut: ["*"])
ALLOWED_ORIGINS=["http://localhost:5173"]

# Duree de validite des tokens d'acces en minutes (defaut: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30
